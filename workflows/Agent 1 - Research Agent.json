        "jsonBody": "={{ { \"message\": { \"content\": $json.band_message, \"mentions\": [ { \"id\": \"f5a81d9f-9608-444d-ba22-c4b9477631c2\", \"name\": \"Agent2 content\", \"handle\": \"aiadpulse12/agent2-content\" } ] } } }}",
