    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { \"status\": \"success\", \"agent\": \"ResearchAgent\", \"product\": $(\"Normalize Input\").item.json.product_name } }}",
        "options": {}
      },
      "id": "2c4498f1-8218-4950-b571-7ed0926f0528",
      "name": "Respond OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.5,
      "position": [
        1456,
        16
      ]
    },
    {
      "parameters": {
        "jsCode": "const normalizedData = $('Normalize Input').item.json;\nconst rawContent = $input.item.json.choices[0].message.content;\n\n// Clean markdown if present\nconst cleanContent = rawContent.replace(/```json/g, '').replace(/```/g, '').trim();\n\n// Parse JSON from AI response\nlet research;\ntry {\n  research = JSON.parse(cleanContent);\n} catch(e) {\n  research = {\n    market_positioning: cleanContent,\n    competitor_angles: [],\n    target_pain_points: [],\n    unique_selling_points: [],\n    recommended_channels: [],\n    urgency_score: 'N/A',\n    research_summary: cleanContent\n  };\n}\n\n// Format into human readable Band message\nconst messageContent = `@aiadpulse12/agent2-content 🔍 RESEARCH COMPLETE\\n\\n📦 Product: ${normalizedData.product_name}\\n👥 Audience: ${normalizedData.target_audience}\\n\\n📊 Market Positioning:\\n${research.market_positioning}\\n\\n🏆 Competitor Angles:\\n- ${(research.competitor_angles || []).join('\\n- ')}\\n\\n😣 Customer Pain Points:\\n- ${(research.target_pain_points || []).join('\\n- ')}\\n\\n✅ Unique Selling Points:\\n- ${(research.unique_selling_points || []).join('\\n- ')}\\n\\n📢 Recommended Channels:\\n${(research.recommended_channels || []).join(', ')}\\n\\n⚡ Urgency Score: ${research.urgency_score}/10\\n\\n📝 Summary:\\n${research.research_summary}\\n\\n➡️ ACTION: Write product copy, email sequence, and 5 ad hooks based on this research.`;\n\nreturn [{\n  json: {\n    product_name: normalizedData.product_name,\n    product_description: normalizedData.product_description,\n    target_audience: normalizedData.target_audience,\n    chat_id: normalizedData.chat_id,\n    research_data: cleanContent,\n    band_message: messageContent,\n    band_api_key: 'band_a_1780862744_chmzhqQwM3pahd9nOOgY-1pXxOoKioVt'\n  }\n}];"
      },
      "id": "fd630886-e76d-4134-9726-87b7ef56bd21",
      "name": "Build Band Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        432,
