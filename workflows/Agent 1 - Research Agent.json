      "id": "c41604d6-1226-430a-98e1-ecfab473fc51",
      "name": "Normalize Input",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        -64,
        32
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.aimlapi.com/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer <Your API key>"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { \"model\": \"google/gemma-3-4b-it\", \"messages\": [ { \"role\": \"user\", \"content\": \"You are a Market Research Agent for an ecommerce product launch system. Analyze the product below and return ONLY a valid JSON object with these exact fields: market_positioning (string), competitor_angles (array of 3 strings), target_pain_points (array of 3 strings), unique_selling_points (array of 3 strings), recommended_channels (array of strings), urgency_score (number 1-10), research_summary (string). Return ONLY the JSON object, no markdown, no explanation, no extra text.\\n\\nProduct: \" + $json.product_name + \"\\nDescription: \" + $json.product_description + \"\\nAudience: \" + $json.target_audience } ], \"temperature\": 0.7, \"max_tokens\": 1024 } }}",
        "options": {
          "redirect": {
            "redirect": {}
          }
        }
      },
      "id": "571eef7f-81dd-49dc-8cb9-5a9e1f2ee37f",
      "name": " Research Analysis",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        192,
        32
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://<your url>.n8n.cloud/webhook/content-agent",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { \"product_name\": $('Build Band Message').item.json.product_name, \"product_description\": $('Build Band Message').item.json.product_description, \"target_audience\": $('Build Band Message').item.json.target_audience, \"chat_id\": $('Build Band Message').item.json.chat_id, \"research_data\": $('Build Band Message').item.json.research_data, \"attempt\": 1 } }}",
        "options": {}
      },
      "id": "7256f42c-9ed9-4c3b-874b-1bf65eaeac3a",
      "name": "Trigger Content Agent",
      "type": "n8n-nodes-base.httpRequest",
