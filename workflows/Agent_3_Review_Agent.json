    {
      "parameters": {
        "method": "POST",
        "url": "https://api.aimlapi.com/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer [REDACTED_AIML_API_KEY]"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { \"model\": \"google/gemma-3-4b-it\", \"messages\": [ { \"role\": \"user\", \"content\": \"You are an extremely strict Content Review Agent for a premium ecommerce brand. You have very high standards. Score the marketing content below on a scale of 1-10. IMPORTANT SCORING RULES:\\n- If this is attempt 1, be very strict. Only score 7+ if the content is truly exceptional with specific benefits, emotional triggers, and strong CTAs.\\n- If content is generic, vague, or lacks specific product benefits, score it 4-6.\\n- If content mentions specific features, pain points, and has compelling hooks, score 7+.\\n\\nReturn ONLY a valid JSON object with these exact fields: overall_score (number 1-10), approved (boolean true ONLY if score is 7 or above), issues_found (array of specific strings describing problems, empty array if approved), revision_notes (string with exact fixes needed, empty string if approved), approval_summary (string). No markdown, no backticks, ONLY raw JSON.\\n\\nProduct: \" + $json.product_name + \"\\nDescription: \" + $json.product_description + \"\\nAudience: \" + $json.target_audience + \"\\nAttempt number: \" + ($json.attempt || 1) + \"\\n\\nContent to review:\\n\" + $json.content_data } ], \"temperature\": 0.2, \"max_tokens\": 800 } }}",
        "options": {}
      },
      "id": "[NODE_ID_REDACTED]",
      "name": "Review Content",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        448,
        -112
      ]
    }
