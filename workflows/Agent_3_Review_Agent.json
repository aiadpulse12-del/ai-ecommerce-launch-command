    {
      "parameters": {
        "jsCode": "const normalizedData = $('Normalize Input').item.json;\nconst reviewResult = $('Parse Review Result').item.json;\n\nconst messageContent = `@[YOUR_BAND_ORG]/[YOUR_AGENT4_HANDLE] ✅ CONTENT APPROVED\\n\\n📦 Product: ${normalizedData.product_name}\\n⭐ Final Score: ${reviewResult.overall_score}/10\\n📝 Summary: ${reviewResult.approval_summary}\\n\\n➡️ ACTION: Build the final campaign brief for this product.`;\n\nreturn [{\n  json: {\n    product_name: normalizedData.product_name,\n    product_description: normalizedData.product_description,\n    target_audience: normalizedData.target_audience,\n    chat_id: normalizedData.chat_id,\n    research_data: normalizedData.research_data,\n    content_data: normalizedData.content_data,\n    overall_score: reviewResult.overall_score,\n    approval_summary: reviewResult.approval_summary,\n    band_message: messageContent,\n    band_api_key: '[REDACTED_BAND_API_KEY]'\n  }\n}];"
      },
      "id": "[NODE_ID_REDACTED]",
      "name": "Build Approval Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        -208
      ]
    },
    {
      "parameters": {
        "jsCode": "const normalizedData = $('Normalize Input').item.json;\nconst reviewResult = $('Parse Review Result').item.json;\n\n// issues_found can be string or array — handle both\nlet issuesText = '';\nif (Array.isArray(reviewResult.issues_found)) {\n  issuesText = reviewResult.issues_found.join('\\n');\n} else if (typeof reviewResult.issues_found === 'string') {\n  issuesText = reviewResult.issues_found;\n} else {\n  issuesText = 'See revision notes below';\n}\n\nconst messageContent = `@[YOUR_BAND_ORG]/[YOUR_AGENT2_HANDLE] ❌ REVISION REQUIRED (Attempt ${normalizedData.attempt || 1}/3)\\n\\n📦 Product: ${normalizedData.product_name}\\n⭐ Score: ${reviewResult.overall_score}/10\\n\\n⚠️ Issues Found:\\n${issuesText}\\n\\n📝 Revision Notes:\\n${reviewResult.revision_notes}\\n\\n➡️ ACTION: Fix ALL issues above and resubmit.`;\n\nreturn [{\n  json: {\n    product_name: normalizedData.product_name,\n    product_description: normalizedData.product_description,\n    target_audience: normalizedData.target_audience,\n    chat_id: normalizedData.chat_id,\n    research_data: normalizedData.research_data,\n    revision_notes: reviewResult.revision_notes,\n    attempt: (normalizedData.attempt || 1) + 1,\n    band_message: messageContent,\n    band_api_key: '[REDACTED_BAND_API_KEY]'\n  }\n}];"
      },
      "id": "[NODE_ID_REDACTED]",
      "name": "Build Revision Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        -16
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "[YOUR_N8N_INSTANCE_URL]/webhook/campaign-agent",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { \"product_name\": $('Build Approval Message').item.json.product_name, \"product_description\": $('Build Approval Message').item.json.product_description, \"target_audience\": $('Build Approval Message').item.json.target_audience, \"chat_id\": $('Build Approval Message').item.json.chat_id, \"research_data\": $('Build Approval Message').item.json.research_data, \"content_data\": $('Build Approval Message').item.json.content_data, \"overall_score\": $('Build Approval Message').item.json.overall_score, \"approval_summary\": $('Build Approval Message').item.json.approval_summary } }}",
        "options": {}
